{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-openclaw-adapter/schemas/blackboard/owner_decision.schema.json",
  "title": "Owner Decision",
  "description": "Owner Decision contract for the single-worker Blackboard loop.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "message_type",
    "created_at",
    "safety_flags",
    "prev_entry_hash",
    "execution_class",
    "produced_by",
    "parent_task_id",
    "role",
    "decision_id",
    "task_id",
    "readiness_id",
    "related_audit_id",
    "decision_status",
    "decided_at",
    "decision_reason",
    "action_available",
    "next_step_allowed",
    "next_step_requires_owner_confirmation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "Blackboard contract version."
    },
    "message_type": {
      "const": "owner_decision",
      "description": "Schema discriminator."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp for this Blackboard entry."
    },
    "safety_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "synthetic_local_only",
        "mock_only",
        "dry_run",
        "owner_review_required",
        "external_side_effects_allowed",
        "external_side_effects_occurred",
        "blackboard_write_allowed",
        "queue_write_allowed",
        "audit_trail_write_allowed",
        "worker_dispatch_allowed",
        "openclaw_call_allowed",
        "hermes_runtime_allowed",
        "connector_call_allowed",
        "google_sheets_write_allowed",
        "follow_up_allowed",
        "follow_up_requires_owner_confirmation"
      ],
      "properties": {
        "synthetic_local_only": {
          "type": "boolean"
        },
        "mock_only": {
          "type": "boolean"
        },
        "dry_run": {
          "type": "boolean"
        },
        "owner_review_required": {
          "type": "boolean"
        },
        "external_side_effects_allowed": {
          "type": "boolean"
        },
        "external_side_effects_occurred": {
          "type": "boolean"
        },
        "blackboard_write_allowed": {
          "type": "boolean"
        },
        "queue_write_allowed": {
          "type": "boolean"
        },
        "audit_trail_write_allowed": {
          "type": "boolean"
        },
        "worker_dispatch_allowed": {
          "type": "boolean"
        },
        "openclaw_call_allowed": {
          "type": "boolean"
        },
        "hermes_runtime_allowed": {
          "type": "boolean"
        },
        "connector_call_allowed": {
          "type": "boolean"
        },
        "google_sheets_write_allowed": {
          "type": "boolean"
        },
        "follow_up_allowed": {
          "type": "boolean"
        },
        "follow_up_requires_owner_confirmation": {
          "type": "boolean"
        }
      },
      "description": "Canonical 16-flag nested boolean object from Owner decision 05 §6.12."
    },
    "prev_entry_hash": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        {
          "type": "null"
        }
      ],
      "description": "Previous entry SHA-256 hash; null is reserved for a genesis entry."
    },
    "execution_class": {
      "type": "string",
      "enum": [
        "AUTO",
        "OWNER_APPROVAL",
        "OWNER_MANUAL"
      ],
      "description": "Execution class inherited from the task."
    },
    "produced_by": {
      "type": "string",
      "minLength": 1,
      "description": "Producing model or component; provenance only, never authorization."
    },
    "parent_task_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ],
      "description": "Parent task id for future decomposition; null for a root task."
    },
    "role": {
      "type": "string",
      "minLength": 1,
      "description": "Functional role of the artifact author; provenance only."
    },
    "decision_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique decision identifier."
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "description": "Related task identifier."
    },
    "readiness_id": {
      "type": "string",
      "minLength": 1,
      "description": "Related readiness identifier."
    },
    "related_audit_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ],
      "description": "Related audit id for post-audit review."
    },
    "decision_status": {
      "type": "string",
      "enum": [
        "PENDING",
        "PASS",
        "HOLD"
      ]
    },
    "decided_at": {
      "oneOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ],
      "description": "Owner decision timestamp; null while pending."
    },
    "decision_reason": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable decision reason."
    },
    "action_available": {
      "type": "boolean",
      "description": "A decision is never dispatch."
    },
    "next_step_allowed": {
      "type": "boolean"
    },
    "next_step_requires_owner_confirmation": {
      "type": "boolean"
    }
  }
}
