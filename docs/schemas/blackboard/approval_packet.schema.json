{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-openclaw-adapter/schemas/blackboard/approval_packet.schema.json",
  "title": "Owner Approval Packet",
  "description": "Phase 4 data-only approval packet for one harmless N=1 query. It grants no execution or dispatch permission.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "message_type",
    "created_at",
    "safety_flags",
    "prev_entry_hash",
    "execution_class",
    "produced_by",
    "parent_task_id",
    "role",
    "approval_packet_id",
    "task_id",
    "action_summary",
    "risk_level",
    "exact_target",
    "expected_side_effects",
    "rollback_path",
    "timeout",
    "dry_run_evidence",
    "audit_trail_preview",
    "approval_timestamp",
    "single_use_execution_token",
    "decision"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "Blackboard contract version."
    },
    "message_type": {
      "const": "approval_packet",
      "description": "Schema discriminator."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp for this Blackboard entry."
    },
    "safety_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "synthetic_local_only",
        "mock_only",
        "dry_run",
        "owner_review_required",
        "external_side_effects_allowed",
        "external_side_effects_occurred",
        "blackboard_write_allowed",
        "queue_write_allowed",
        "audit_trail_write_allowed",
        "worker_dispatch_allowed",
        "openclaw_call_allowed",
        "hermes_runtime_allowed",
        "connector_call_allowed",
        "google_sheets_write_allowed",
        "follow_up_allowed",
        "follow_up_requires_owner_confirmation"
      ],
      "properties": {
        "synthetic_local_only": {"type": "boolean"},
        "mock_only": {"type": "boolean"},
        "dry_run": {"type": "boolean"},
        "owner_review_required": {"type": "boolean"},
        "external_side_effects_allowed": {"type": "boolean"},
        "external_side_effects_occurred": {"type": "boolean"},
        "blackboard_write_allowed": {"type": "boolean"},
        "queue_write_allowed": {"type": "boolean"},
        "audit_trail_write_allowed": {"type": "boolean"},
        "worker_dispatch_allowed": {"type": "boolean"},
        "openclaw_call_allowed": {"type": "boolean"},
        "hermes_runtime_allowed": {"type": "boolean"},
        "connector_call_allowed": {"type": "boolean"},
        "google_sheets_write_allowed": {"type": "boolean"},
        "follow_up_allowed": {"type": "boolean"},
        "follow_up_requires_owner_confirmation": {"type": "boolean"}
      },
      "description": "Canonical 16-flag nested boolean object from Owner decision 05 §6.12."
    },
    "prev_entry_hash": {
      "oneOf": [
        {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        {"type": "null"}
      ],
      "description": "Previous entry SHA-256 hash; null is reserved for a genesis or preview entry."
    },
    "execution_class": {
      "const": "AUTO",
      "description": "N=1 harmless read-only query class; this is not current execution authorization."
    },
    "produced_by": {
      "type": "string",
      "minLength": 1,
      "description": "Producing component; provenance only, never authorization."
    },
    "parent_task_id": {
      "oneOf": [
        {"type": "string", "minLength": 1},
        {"type": "null"}
      ],
      "description": "Parent task id reserved for future decomposition."
    },
    "role": {
      "type": "string",
      "minLength": 1,
      "description": "Functional role of the artifact author; provenance only."
    },
    "approval_packet_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique packet correlation identifier."
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "description": "The one task covered by this packet."
    },
    "action_summary": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable summary of the single harmless query."
    },
    "risk_level": {
      "const": "low",
      "description": "N=1 harmless query risk classification."
    },
    "exact_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_type", "task_id", "command_id", "query_action"],
      "properties": {
        "action_type": {"const": "n1_harmless_query"},
        "task_id": {"type": "string", "minLength": 1},
        "command_id": {"type": "string", "minLength": 1},
        "query_action": {"type": "string", "minLength": 1}
      },
      "description": "Exact correlation and action for one harmless query only."
    },
    "expected_side_effects": {
      "type": "array",
      "items": {"type": "string"},
      "maxItems": 0,
      "description": "Must remain empty for the harmless N=1 query."
    },
    "rollback_path": {
      "type": "string",
      "minLength": 1,
      "description": "Why rollback is unnecessary for the unexecuted query preview."
    },
    "timeout": {
      "const": 30,
      "description": "Fixed timeout in seconds for the N=1 query design. It is inert in Phase 4."
    },
    "dry_run_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dry_run_id", "result_id", "result_status", "preview_only"],
      "properties": {
        "dry_run_id": {"type": "string", "minLength": 1},
        "result_id": {"type": "string", "minLength": 1},
        "result_status": {"const": "preview_result_not_executed"},
        "preview_only": {"const": true}
      },
      "description": "References to the dry-run and result messages used as evidence."
    },
    "audit_trail_preview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "persisted"],
      "properties": {
        "summary": {"type": "string", "minLength": 1},
        "persisted": {"const": false}
      },
      "description": "Display-only audit preview; no audit write occurs."
    },
    "approval_timestamp": {
      "oneOf": [
        {"type": "string", "format": "date-time"},
        {"type": "null"}
      ],
      "description": "Synthetic decision timestamp; null while awaiting an offline Owner response."
    },
    "single_use_execution_token": {
      "type": "null",
      "const": null,
      "description": "Locked to null in Phase 4; real token design belongs to Phase 9."
    },
    "decision": {
      "type": "string",
      "enum": ["approve", "edit", "reject", "respond"],
      "description": "Inert offline decision data; never dispatch permission."
    }
  }
}
