{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-openclaw-adapter/schemas/blackboard/worker_dry_run.schema.json",
  "title": "Worker Dry-run",
  "description": "Worker Dry-run contract for the single-worker Blackboard loop.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "message_type",
    "created_at",
    "safety_flags",
    "prev_entry_hash",
    "execution_class",
    "produced_by",
    "parent_task_id",
    "role",
    "dry_run_id",
    "task_id",
    "decision_id",
    "task_title",
    "task_summary",
    "proposed_worker_action",
    "dry_run_status",
    "preview_only",
    "permissions",
    "runtime_state",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "Blackboard contract version."
    },
    "message_type": {
      "const": "worker_dry_run",
      "description": "Schema discriminator."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp for this Blackboard entry."
    },
    "safety_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "synthetic_local_only",
        "mock_only",
        "dry_run",
        "owner_review_required",
        "external_side_effects_allowed",
        "external_side_effects_occurred",
        "blackboard_write_allowed",
        "queue_write_allowed",
        "audit_trail_write_allowed",
        "worker_dispatch_allowed",
        "openclaw_call_allowed",
        "hermes_runtime_allowed",
        "connector_call_allowed",
        "google_sheets_write_allowed",
        "follow_up_allowed",
        "follow_up_requires_owner_confirmation"
      ],
      "properties": {
        "synthetic_local_only": {
          "type": "boolean"
        },
        "mock_only": {
          "type": "boolean"
        },
        "dry_run": {
          "type": "boolean"
        },
        "owner_review_required": {
          "type": "boolean"
        },
        "external_side_effects_allowed": {
          "type": "boolean"
        },
        "external_side_effects_occurred": {
          "type": "boolean"
        },
        "blackboard_write_allowed": {
          "type": "boolean"
        },
        "queue_write_allowed": {
          "type": "boolean"
        },
        "audit_trail_write_allowed": {
          "type": "boolean"
        },
        "worker_dispatch_allowed": {
          "type": "boolean"
        },
        "openclaw_call_allowed": {
          "type": "boolean"
        },
        "hermes_runtime_allowed": {
          "type": "boolean"
        },
        "connector_call_allowed": {
          "type": "boolean"
        },
        "google_sheets_write_allowed": {
          "type": "boolean"
        },
        "follow_up_allowed": {
          "type": "boolean"
        },
        "follow_up_requires_owner_confirmation": {
          "type": "boolean"
        }
      },
      "description": "Canonical 16-flag nested boolean object from Owner decision 05 §6.12."
    },
    "prev_entry_hash": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        {
          "type": "null"
        }
      ],
      "description": "Previous entry SHA-256 hash; null is reserved for a genesis entry."
    },
    "execution_class": {
      "type": "string",
      "enum": [
        "AUTO",
        "OWNER_APPROVAL"
      ],
      "description": "Execution class inherited from the task."
    },
    "produced_by": {
      "type": "string",
      "minLength": 1,
      "description": "Producing model or component; provenance only, never authorization."
    },
    "parent_task_id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ],
      "description": "Parent task id for future decomposition; null for a root task."
    },
    "role": {
      "type": "string",
      "minLength": 1,
      "description": "Functional role of the artifact author; provenance only."
    },
    "dry_run_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique dry-run identifier."
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "description": "Related task identifier."
    },
    "decision_id": {
      "type": "string",
      "minLength": 1,
      "description": "Related Owner decision identifier."
    },
    "task_title": {
      "type": "string",
      "minLength": 1,
      "description": "Task title snapshot."
    },
    "task_summary": {
      "type": "string",
      "minLength": 1,
      "description": "Task summary snapshot."
    },
    "proposed_worker_action": {
      "type": "string",
      "minLength": 1,
      "description": "Preview of hypothetical Worker action."
    },
    "dry_run_status": {
      "type": "string",
      "enum": [
        "preview_only_not_executed",
        "hold"
      ]
    },
    "preview_only": {
      "const": true,
      "description": "Worker dry-run is always preview only."
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_permission",
        "dispatch_permission",
        "external_side_effects_permission",
        "result_persistence_permission",
        "audit_trail_write_permission"
      ],
      "properties": {
        "execution_permission": {
          "type": "boolean"
        },
        "dispatch_permission": {
          "type": "boolean"
        },
        "external_side_effects_permission": {
          "type": "boolean"
        },
        "result_persistence_permission": {
          "type": "boolean"
        },
        "audit_trail_write_permission": {
          "type": "boolean"
        }
      }
    },
    "runtime_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worker_started",
        "worker_loop_started",
        "task_executed",
        "openclaw_called",
        "hermes_called",
        "google_sheets_enabled",
        "real_queue_db_read",
        "queue_written",
        "post_enabled",
        "secrets_read",
        "webhook_created",
        "endpoint_created",
        "connector_created",
        "production_db_created",
        "remote_blackboard_api_runtime_created"
      ],
      "properties": {
        "worker_started": {
          "type": "boolean"
        },
        "worker_loop_started": {
          "type": "boolean"
        },
        "task_executed": {
          "type": "boolean"
        },
        "openclaw_called": {
          "type": "boolean"
        },
        "hermes_called": {
          "type": "boolean"
        },
        "google_sheets_enabled": {
          "type": "boolean"
        },
        "real_queue_db_read": {
          "type": "boolean"
        },
        "queue_written": {
          "type": "boolean"
        },
        "post_enabled": {
          "type": "boolean"
        },
        "secrets_read": {
          "type": "boolean"
        },
        "webhook_created": {
          "type": "boolean"
        },
        "endpoint_created": {
          "type": "boolean"
        },
        "connector_created": {
          "type": "boolean"
        },
        "production_db_created": {
          "type": "boolean"
        },
        "remote_blackboard_api_runtime_created": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "description": "Dry-run boundary notes."
    }
  }
}
