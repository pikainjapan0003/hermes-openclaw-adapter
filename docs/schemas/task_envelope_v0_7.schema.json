{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hermes-openclaw-adapter/schemas/task_envelope_v0_7.schema.json",
  "title": "TaskEnvelope v0.7",
  "description": "Adapter 收到 Hermes 任務後正規化的 Queue TaskEnvelope 契約（v0.7.0-B，純 mock，不含任何 secret）。",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "task_id",
    "created_at",
    "created_by",
    "source",
    "requested_by",
    "risk_level",
    "approval_required",
    "approval_status",
    "intent",
    "goal",
    "task_type",
    "priority",
    "input_summary",
    "target_runtime",
    "target_workspace",
    "idempotency_key",
    "max_retries",
    "retry_count",
    "status",
    "result_policy",
    "callback_policy",
    "metadata"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "唯一 id（adapter 產生）。"
    },
    "created_at": {
      "type": "string",
      "description": "ISO8601 UTC 時間戳。"
    },
    "created_by": {
      "type": "string",
      "description": "hermes / owner / system。"
    },
    "source": {
      "type": "string",
      "description": "來源（discord / dashboard / hermes-agent ...）。"
    },
    "requested_by": {
      "type": "string",
      "description": "實際請求者識別（非 secret）。"
    },
    "risk_level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4,
      "description": "0..4 approval model 風險等級。"
    },
    "approval_required": {
      "type": "boolean",
      "description": "是否需要批准。"
    },
    "approval_status": {
      "type": "string",
      "enum": ["not_required", "pending", "approved", "rejected"],
      "description": "批准狀態。"
    },
    "intent": {
      "type": "string",
      "description": "高層意圖（人類可讀）。"
    },
    "goal": {
      "type": "string",
      "description": "目標描述。"
    },
    "task_type": {
      "type": "string",
      "description": "類別（query / action / pipeline ...）。"
    },
    "priority": {
      "type": "string",
      "description": "low / normal / high。"
    },
    "input_summary": {
      "type": "string",
      "description": "摘要（不含 secret）。"
    },
    "input_payload_ref": {
      "type": ["string", "null"],
      "description": "指向 payload 的參考（不內嵌 secret）。"
    },
    "allowed_tools": {
      "type": "array",
      "items": { "type": "string" },
      "description": "允許工具白名單。"
    },
    "denied_tools": {
      "type": "array",
      "items": { "type": "string" },
      "description": "禁用工具黑名單。"
    },
    "target_runtime": {
      "type": "string",
      "description": "openclaw / mock ...。"
    },
    "target_workspace": {
      "type": "string",
      "description": "目標工作區（非 secret）。"
    },
    "idempotency_key": {
      "type": "string",
      "description": "去重鍵。"
    },
    "max_retries": {
      "type": "integer",
      "minimum": 0,
      "description": "重試上限（非負整數）。"
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "description": "目前重試次數（非負整數）。"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "pending_approval",
        "queued",
        "dispatching",
        "running",
        "callback_received",
        "completed",
        "failed",
        "cancelled",
        "dead_letter"
      ],
      "description": "TaskEnvelope 狀態機狀態值。"
    },
    "result_policy": {
      "type": "object",
      "description": "結果落地策略（none / ledger / sink ...）。"
    },
    "callback_policy": {
      "type": "object",
      "description": "callback 策略（ledger_only / http ...）。"
    },
    "metadata": {
      "type": "object",
      "description": "其他非敏感中繼資料。"
    }
  }
}
