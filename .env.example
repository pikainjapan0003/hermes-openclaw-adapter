# Hermes 呼叫 Adapter 時要帶這個 token。
# 新手測試可以先用 change-me，正式使用請改成長一點的亂數。
HERMES_ADAPTER_TOKEN=change-me

# OpenClaw 串接模式。
#   cli      = 用 OpenClaw CLI 真實派任務（預設、推薦）
#   dry_run  = 只組任務文字、不真的呼叫 OpenClaw（沒裝 OpenClaw 時測流程用）
OPENCLAW_TRANSPORT=cli

# OpenClaw CLI 執行檔名稱或絕對路徑。
# Adapter 必須跑在能存取這個指令的環境（WSL Ubuntu，PATH 內有 openclaw）。
OPENCLAW_CLI_BIN=openclaw

# Adapter 呼叫 OpenClaw CLI 的逾時秒數（OpenClaw agent 預設就要 600 秒等級）。
OPENCLAW_CLI_TIMEOUT_SECONDS=600

# 要跑哪個 OpenClaw agent（對應 `openclaw status` 的 default agent）。
# 預設 main；openclaw agent 一定要有 target session，否則會回 "No target session selected"。
OPENCLAW_AGENT_ID=main

# 每個 Hermes 任務用獨立 session 的前綴（最終 session-key = agent:<agent>:<prefix>-<task_id>）。
OPENCLAW_SESSION_KEY_PREFIX=hermes

# 任務紀錄資料夾
DATA_DIR=data
