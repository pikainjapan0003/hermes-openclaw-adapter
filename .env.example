# Hermes 呼叫 Adapter 時要帶這個 token。
HERMES_ADAPTER_TOKEN=change-me

# --- Dashboard Auth Gate (v0.6.4) ---
# 本機開發可 false（維持舊行為，不需登入）。
# Replit / 任何公開環境「必須」設為 true，否則 Dashboard 控制表單會裸露。
# DASHBOARD_TOKEN 請放 Replit Secrets，不要 commit；docs 不放真值。
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_TOKEN=replace-with-dashboard-token

# --- OpenClaw CLI ---
OPENCLAW_CLI_BIN=openclaw
OPENCLAW_AGENT_ID=main
OPENCLAW_SESSION_KEY_PREFIX=hermes
# 背景執行 OpenClaw CLI 的逾時秒數（v0.4 預設 180）。
OPENCLAW_TIMEOUT_SECONDS=180

# 任務 / 結果 / callback 紀錄資料夾
DATA_DIR=data

# --- v0.5 Queue Worker ---
# 執行模式：
#   queue      = 寫入本地 SQLite queue，由 `python -m app.worker` 執行（v0.5 預設）
#   background = v0.4 舊行為，直接用 FastAPI 背景執行（不需 worker）
EXECUTION_MODE=queue
# 本地 queue 資料庫路徑（預設 data/queue.db）
QUEUE_DB_PATH=data/queue.db
# 任務最大嘗試次數（達上限後標記 failed）
QUEUE_MAX_ATTEMPTS=3
# worker 輪詢間隔（秒）
WORKER_POLL_INTERVAL_SECONDS=2
# worker 重試前的等待秒數
WORKER_RETRY_BACKOFF_SECONDS=5

# --- Callback (v0.4) ---
# 完成後是否要 callback。
CALLBACK_ENABLED=true
# ledger_only = 只把結果寫進 data/results.jsonl（預設，不送 HTTP）
# http        = 額外 POST 到 HERMES_CALLBACK_URL（帶 HMAC 簽章）
HERMES_CALLBACK_MODE=ledger_only
# 只有 http 模式才會用到下面幾項：
HERMES_CALLBACK_URL=http://127.0.0.1:8644/webhooks/openclaw-result
# HMAC 用的密鑰，請改成長亂數，不要 commit。
HERMES_CALLBACK_SECRET=replace-me-long-random-secret
CALLBACK_MAX_RETRIES=3
CALLBACK_TIMEOUT_SECONDS=20
